# noui-platform environment variables
# Copy to .env and adjust values for your environment

# --- PostgreSQL (shared by dataaccess, crm, knowledgebase, dataquality, correspondence) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=derp
DB_PASSWORD=derp
DB_NAME=derp
DB_SSLMODE=disable

# --- Service ports ---
# dataaccess
DATAACCESS_PORT=8081
# intelligence
INTELLIGENCE_PORT=8082
# crm (internal 8083, host-mapped to 8084)
CRM_PORT=8083
# correspondence
CORRESPONDENCE_PORT=8085
# dataquality
DATAQUALITY_PORT=8086
# knowledgebase
KNOWLEDGEBASE_PORT=8087
# connector
CONNECTOR_PORT=8090

# --- Service URLs (used for inter-service calls) ---
# intelligence calls dataaccess via this URL
CONNECTOR_URL=http://localhost:8081

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
# Vite dev server
VITE_PORT=3000
